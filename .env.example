# ═══════════════════════════════════════════════════════════════════
#  Laptop Diagnostics System — Server Configuration
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── MongoDB ────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/laptop_diagnostics

# ── Flask ──────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
PORT=5000
FLASK_DEBUG=false

# ── Agent Authentication ───────────────────────────────────────────
# Every agent must send this key in the X-Agent-Key header.
# Without this, any machine on the network could register itself.
# Generate:  python -c "import secrets; print(secrets.token_hex(32))"
AGENT_API_KEY=replace_with_a_long_random_string

# ── SMTP / Email Alerts ────────────────────────────────────────────
# Gmail: use an App Password, NOT your account password.
# Go to: Google Account → Security → 2-Step Verification → App passwords
#
# These are fallback values. Settings saved in the web UI (Settings page)
# are stored in MongoDB and take precedence over these env vars.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ── Agent Quick Reference ──────────────────────────────────────────
# On each laptop you want to monitor, set ONLY these two vars:
#
#   DIAG_SERVER_URL = http://<this-server-ip>:5000
#   DIAG_API_KEY    = <same value as AGENT_API_KEY above>
#
# Then run:  python laptop_agent.py
# The laptop registers itself and appears in the dashboard instantly.
# No manual registration needed.
