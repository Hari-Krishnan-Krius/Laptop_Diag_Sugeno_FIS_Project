# ─────────────────────────────────────────────────────────────
#  Laptop Diagnostics System — Environment Configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/laptop_diagnostics

# Flask secret key (change this in production!)
SECRET_KEY=change_me_to_a_long_random_string

# ── Email / SMTP ──────────────────────────────────────────────
# Gmail example: use an App Password, not your account password
# Go to: Google Account → Security → 2-Step Verification → App passwords
# SMTP settings can also be configured via the Settings page in the UI.
# Settings saved in the UI are stored in MongoDB and take precedence.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ── Multi-worker / Gunicorn note ──────────────────────────────
# When running with multiple workers (e.g. gunicorn -w 4), only one
# worker process will run the background scheduler threads. This is
# coordinated automatically via a MongoDB lock (scheduler_locks collection).
# If you need to reset the lock (e.g. after a hard crash), run:
#   mongo laptop_diagnostics --eval 'db.scheduler_locks.deleteOne({_id:"scheduler_owner"})'
